  "keyFeatures": [
    "Hindley-Milner type system with complete type inference",
    "Structural pattern matching with exhaustiveness checking",
    "Algebraic data types (sum types and product types)",
    "Pure functions with explicit IO monad for side effects",
    "JVM bytecode compilation with optional interpreter",
    "Haskell-inspired functional syntax",
    "Standard library with List, String, Option, Result types",
    "Multi-pass compiler architecture"
  ],
  "publicApiSurface": [
    "elara build <file> - Compile Elara source files to JVM bytecode",
    "elara run <file> --target [interp|jvm] - Run Elara programs",
    "def - Function and type signature declarations",
    "let - Value and function bindings",
    "type - Algebraic data type definitions",
    "type alias - Type aliases",
    "match...with - Pattern matching expressions",
    "import - Module imports",
    "IO () - IO monad for effectful computations",
    "List, Option, Result, String - Core standard library types"
  ]
}
